\name{investlabr-package}
\alias{investlabr}
\alias{investlabr-package}
\title{investlabr: Research workflows for macro and cross-asset analysis}
\description{
Reusable research workflows for macro-financial and cross-asset analysis.
\code{investlabr} sits on top of data-access packages such as
\code{investdatar} and focuses on turning existing market and macro datasets
into analysis-ready tables, factor constructions, event and regime overlays,
sensitivity estimates, scenario comparisons, and research-grade visualization
outputs.
}
\details{
Intended module families include \code{prep_*}, \code{factor_*},
\code{event_*}, \code{regime_*}, \code{sense_*}, \code{sim_*},
\code{viz_*}, and \code{brief_*}.

\code{investlabr} does not own raw data downloading, sync infrastructure,
trading execution, portfolio accounting, or LLM orchestration.
}
\keyword{internal}

